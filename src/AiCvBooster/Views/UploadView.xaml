<UserControl x:Class="AiCvBooster.Views.UploadView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:AiCvBooster.Converters"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             AllowDrop="True"
             DragEnter="OnDragEnter"
             DragLeave="OnDragLeave"
             Drop="OnDrop">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:BoolToVisibilityConverter x:Key="InvBoolToVis" Invert="True"/>
    </UserControl.Resources>

    <Grid Margin="32,8,32,32">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: Hero + drop zone -->
        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,24,0">
            <TextBlock Text="Make your CV stand out"
                       Style="{StaticResource Text.Display}"/>
            <TextBlock Text="Upload your resume. Our AI rewrites it for clarity, impact, and ATS-friendliness — without inventing anything."
                       Style="{StaticResource Text.Subtitle}"
                       Margin="0,10,0,28"
                       MaxWidth="640" HorizontalAlignment="Left"/>

            <!-- Drop zone -->
            <Border x:Name="DropZone"
                    Background="#141E33"
                    BorderBrush="{StaticResource BorderBrush.Soft}"
                    BorderThickness="2"
                    CornerRadius="16"
                    Padding="40"
                    MinHeight="260"
                    SnapsToDevicePixels="True">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="6" Opacity="0.35" Color="Black"/>
                </Border.Effect>

                <Grid>
                    <!-- Empty state -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding HasDocument, Converter={StaticResource InvBoolToVis}}">
                        <Border Width="72" Height="72" CornerRadius="18"
                                Background="#1F2A44"
                                HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="CloudUploadOutline"
                                                     Width="36" Height="36"
                                                     Foreground="{StaticResource PrimaryBrush}"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Drop your CV here"
                                   FontSize="20" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,18,0,6"/>
                        <TextBlock Text="PDF or DOCX"
                                   Style="{StaticResource Text.Muted}"
                                   HorizontalAlignment="Center"/>
                        <Button Content="Upload CV"
                                Style="{StaticResource Btn.Primary}"
                                HorizontalAlignment="Center"
                                Margin="0,22,0,0"
                                Command="{Binding PickFileCommand}"/>
                    </StackPanel>

                    <!-- Loaded state -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding HasDocument, Converter={StaticResource BoolToVis}}">
                        <Border Width="72" Height="72" CornerRadius="18"
                                Background="#1C3A2A"
                                HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="FileDocumentCheckOutline"
                                                     Width="36" Height="36"
                                                     Foreground="{StaticResource AccentBrush}"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding FileName}"
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,16,0,4"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="520"/>
                        <TextBlock Text="{Binding StatusText}"
                                   Style="{StaticResource Text.Muted}"
                                   HorizontalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,18,0,0">
                            <Button Content="Choose another"
                                    Style="{StaticResource Btn.Ghost}"
                                    Command="{Binding PickFileCommand}"
                                    Margin="0,0,12,0"/>
                            <Button Content="Boost My CV"
                                    Style="{StaticResource Btn.Primary}"
                                    Command="{Binding BoostCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ════════════════════════════════════════════════════════
                 Error banner (dark-themed, icon + left accent bar,
                 scrollable if the message is long). Hidden when null.
                 ════════════════════════════════════════════════════════ -->
            <Border Margin="0,16,0,0">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource ErrorBanner}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- left accent bar -->
                    <Border Grid.Column="0"
                            Background="{StaticResource DangerBrush}"
                            CornerRadius="2"
                            Margin="0,2,12,2"/>

                    <materialDesign:PackIcon Grid.Column="1"
                                             Kind="AlertOctagonOutline"
                                             Width="22" Height="22"
                                             VerticalAlignment="Top"
                                             Margin="0,1,12,0"
                                             Foreground="{StaticResource DangerBrush}"/>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Something went wrong"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,0,0,2"/>
                        <ScrollViewer MaxHeight="90"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <TextBlock Text="{Binding ErrorMessage}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="13"
                                       TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>

        <!-- RIGHT: Options card -->
        <Border Grid.Column="1" Style="{StaticResource Card}" VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Options" Style="{StaticResource Text.Title}" Margin="0,0,0,16"/>

                <TextBlock Text="TARGET JOB DESCRIPTION (OPTIONAL)"
                           Style="{StaticResource Text.Label}"
                           Margin="0,0,0,8"/>
                <TextBox Style="{StaticResource Input.TextBox}"
                         Text="{Binding JobDescription, UpdateSourceTrigger=PropertyChanged}"
                         Height="170"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"/>
                <TextBlock Text="Paste a role — the AI will mirror relevant keywords."
                           Style="{StaticResource Text.Muted}"
                           FontSize="12" Margin="2,6,0,18"/>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Aggressive mode" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Bolder tone, high-agency language."
                                   Style="{StaticResource Text.Muted}" FontSize="12"/>
                    </StackPanel>
                    <ToggleButton Grid.Column="1"
                                  IsChecked="{Binding AggressiveMode}"
                                  Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                  VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
