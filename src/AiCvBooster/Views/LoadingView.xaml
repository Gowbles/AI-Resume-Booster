<UserControl x:Class="AiCvBooster.Views.LoadingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Grid>
        <Border Style="{StaticResource Card}"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="520" Padding="40">
            <StackPanel HorizontalAlignment="Center">
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                             IsIndeterminate="True"
                             Value="0"
                             Width="64" Height="64"
                             Foreground="{StaticResource PrimaryBrush}"/>

                <TextBlock Text="{Binding StatusText}"
                           FontSize="22" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,22,0,6"/>
                <TextBlock Text="{Binding SubText}"
                           Style="{StaticResource Text.Muted}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           MaxWidth="360"/>

                <!-- Pulsing dots -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,26,0,0">
                    <StackPanel.Resources>
                        <Style TargetType="Ellipse">
                            <Setter Property="Width" Value="10"/>
                            <Setter Property="Height" Value="10"/>
                            <Setter Property="Margin" Value="6,0"/>
                            <Setter Property="Fill" Value="{StaticResource PrimaryBrush}"/>
                        </Style>
                    </StackPanel.Resources>
                    <Ellipse x:Name="Dot1" Opacity="0.3"/>
                    <Ellipse x:Name="Dot2" Opacity="0.3"/>
                    <Ellipse x:Name="Dot3" Opacity="0.3"/>
                </StackPanel>

                <Button Content="Cancel"
                        Style="{StaticResource Btn.Ghost}"
                        Command="{Binding CancelCommand}"
                        HorizontalAlignment="Center"
                        Margin="0,28,0,0"/>
            </StackPanel>
        </Border>
    </Grid>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard RepeatBehavior="Forever">
                    <DoubleAnimation Storyboard.TargetName="Dot1"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.3" To="1.0" Duration="0:0:0.5"
                                     AutoReverse="True"/>
                    <DoubleAnimation Storyboard.TargetName="Dot2"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.3" To="1.0" Duration="0:0:0.5"
                                     BeginTime="0:0:0.15"
                                     AutoReverse="True"/>
                    <DoubleAnimation Storyboard.TargetName="Dot3"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.3" To="1.0" Duration="0:0:0.5"
                                     BeginTime="0:0:0.30"
                                     AutoReverse="True"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>
</UserControl>
