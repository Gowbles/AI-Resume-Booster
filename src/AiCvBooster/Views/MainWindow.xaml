<Window x:Class="AiCvBooster.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AiCvBooster.ViewModels"
        xmlns:views="clr-namespace:AiCvBooster.Views"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="AI CV Booster"
        Height="820" Width="1240"
        MinHeight="680" MinWidth="1060"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        TextElement.Foreground="{StaticResource TextPrimaryBrush}"
        TextElement.FontFamily="{StaticResource AppFontFamily}"
        FontFamily="{StaticResource AppFontFamily}"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        UseLayoutRounding="True">

    <!-- WindowChrome lets us keep native drag/resize but own the caption area -->
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:UploadViewModel}">
            <views:UploadView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LoadingViewModel}">
            <views:LoadingView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ResultViewModel}">
            <views:ResultView/>
        </DataTemplate>
    </Window.Resources>

    <!-- Outer border — provides rounded corners + drop shadow via margin -->
    <Border x:Name="RootBorder"
            Margin="12"
            CornerRadius="14"
            Background="{StaticResource BackgroundGradientBrush}"
            BorderBrush="#22FFFFFF"
            BorderThickness="1"
            ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.65" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>  <!-- custom title bar -->
                <RowDefinition Height="Auto"/> <!-- brand header -->
                <RowDefinition Height="*"/>    <!-- content -->
            </Grid.RowDefinitions>

            <!-- ═══════════════════════════════════════════════════════════
                 Custom title bar
                 • Mac-style traffic lights top-left (Close / Min / Max)
                 • Window title centered
                 • Caption area dragable via WindowChrome
                 ═══════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="0" Background="Transparent">
                <!-- Buttons must opt out of the drag caption -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Margin="18,0,0,0"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="CloseBtn"
                            Style="{StaticResource MacBtn.Close}"
                            Click="CloseBtn_Click"/>
                    <Button x:Name="MinimizeBtn"
                            Style="{StaticResource MacBtn.Minimize}"
                            Click="MinimizeBtn_Click"/>
                    <Button x:Name="MaximizeBtn"
                            Style="{StaticResource MacBtn.Maximize}"
                            Click="MaximizeBtn_Click"/>
                </StackPanel>

                <TextBlock Text="AI CV Booster"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="12"
                           FontWeight="Medium"
                           Opacity="0.85"/>
            </Grid>

            <!-- ═══════════════════════════════════════════════════════════
                 Brand header (logo + tagline). Lives beneath the title bar
                 and stays in sync with the rest of the theme.
                 ═══════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="1" Margin="32,4,32,12">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="40" Height="40" CornerRadius="12"
                            Background="{StaticResource PrimaryGradientBrush}">
                        <materialDesign:PackIcon Kind="AutoFix"
                                                 Width="22" Height="22"
                                                 Foreground="White"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="AI CV Booster" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Make your CV stand out with AI"
                                   FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Content area -->
            <ContentControl Grid.Row="2" Content="{Binding CurrentView}"/>
        </Grid>
    </Border>
</Window>
